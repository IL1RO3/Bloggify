# Copy to /etc/bloggify/bloggify.env and fill in real values.
# Never commit the real production file.
# Set BLOGGIFY_ENV_FILE only if you store this somewhere other than /etc/bloggify/bloggify.env.

DJANGO_SECRET_KEY='replace-with-a-generated-secret-key'
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_USE_HTTPS=True
DJANGO_ENABLE_DEBUG_TOOLBAR=False

POSTGRES_SERVICE=bloggify
POSTGRES_PASSFILE=/etc/bloggify/pgpass
PGSERVICEFILE=/etc/bloggify/pg_service.conf
POSTGRES_CONN_MAX_AGE=60

DEFAULT_FROM_EMAIL='Bloggify <noreply@example.com>'
SERVER_EMAIL='Bloggify <errors@example.com>'

# Option A: Google Apps Script mail gateway.
BLOGGIFY_MAIL_GATEWAY_URL=''
BLOGGIFY_MAIL_GATEWAY_TOKEN=''

# Option B: SMTP provider. Uncomment and fill if using SMTP instead.
# DJANGO_EMAIL_BACKEND='django.core.mail.backends.smtp.EmailBackend'
# DJANGO_EMAIL_HOST='smtp.example.com'
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER='smtp-user'
# DJANGO_EMAIL_HOST_PASSWORD='smtp-password'
# DJANGO_EMAIL_USE_TLS=True
